# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your Apps → SDK setup & configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# HKBU GenAI Platform
# Get this from https://genai.hkbu.edu.hk
VITE_HKBU_GENAI_API_KEY=your_hkbu_genai_api_key
VITE_HKBU_GENAI_MODEL=gpt-4.1

# Cloudinary (used by the event scraper to re-host images)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
